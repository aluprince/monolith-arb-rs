# Environment flag - controls whether we hit testnet or live
ENVIRONMENT=live

# Minimum net profit to consider an opportunity worth executing (0.8%)
MIN_NET_PROFIT_THRESHOLD=0.008

# Maximum age of price data before we reject it as stale (milliseconds)
MAX_PRICE_AGE_MS=500

# How much of our rate limit budget we're willing to use (85%)
RATE_LIMIT_BUDGET=0.85

# STREAM ENDPOINT
WS_URL_TESTNET=wss://testnet.binance.vision/ws/!bookTicker
WS_URL_LIVE=wss://stream.binance.com:9443/ws/!bookTicker
